# ─── Server ───────────────────────────────────
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/curi

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── AI Providers ─────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
STABILITY_API_KEY=sk-...
RUNWAY_API_KEY=...
ELEVENLABS_API_KEY=...
FAL_KEY=...
PERPLEXITY_API_KEY=pplx-...

# ─── Social Media OAuth ────────────────────────
PUBLIC_API_URL=http://localhost:5001
LINKEDIN_CLIENT_ID=...
LINKEDIN_CLIENT_SECRET=...
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_ID=

TWITTER_CLIENT_ID=...
TWITTER_CLIENT_SECRET=...
# Also supported: X_CONSUMER_KEY, X_SECRET_KEY, X_ACCESS_TOKEN, X_USER_ID
TWITTER_ACCESS_TOKEN=
TWITTER_USER_ID=

INSTAGRAM_APP_ID=...
INSTAGRAM_APP_SECRET=...
FACEBOOK_LOGIN_CONFIG_ID=...
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

FACEBOOK_APP_ID=...
FACEBOOK_APP_SECRET=...
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# Vercel cron (optional — secures /api/cron/publish)
CRON_SECRET=

TIKTOK_CLIENT_KEY=...
TIKTOK_CLIENT_SECRET=...

# ─── Email Providers ───────────────────────────
RESEND_API_KEY=re_...
MAILCHIMP_API_KEY=...
KLAVIYO_API_KEY=...

# ─── Payments ─────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Storage ──────────────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=curi-assets

# ─── Web Scraping ──────────────────────────────
BROWSERLESS_TOKEN=...

# ─── Client (Vite) ─────────────────────────────
VITE_API_URL=http://localhost:5000/api
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
