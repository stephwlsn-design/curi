{
  "name": "curi-platform",
  "version": "1.0.0",
  "description": "Curi – AI-Powered Marketing & Content Creation Platform",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "build": "cd client && npm run build",
    "deploy:prod": "docker compose -f docker-compose.prod.yml up -d --build",
    "deploy:check": "bash deploy/check.sh",
    "deploy:git": "bash deploy/git-deploy.sh",
    "deploy:logs": "docker compose -f docker-compose.prod.yml logs -f",
    "test": "cd server && npm test"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "mongodb": "^7.3.0"
  }
}
